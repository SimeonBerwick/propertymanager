generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum RequestStatus {
  new
  scheduled
  in_progress
  done
}

enum Urgency {
  low
  medium
  high
  urgent
}

enum CurrencyOption {
  usd
  peso
  pound
  euro
}

enum LanguageOption {
  english
  spanish
  french
}

enum TenantIdentityStatus {
  pending_invite
  active
  inactive
  moved_out
}

enum TenantInviteStatus {
  pending
  accepted
  expired
  revoked
}

enum TenantOtpPurpose {
  invite_login
  returning_login
}

enum TenantOtpChannel {
  sms
  email
}

enum TenantEventVisibility {
  internal
  tenant_visible
}

enum DispatchStatus {
  assigned
  contacted
  accepted
  declined
  scheduled
  completed
}

enum PhotoSource {
  tenant
  landlord
  vendor
}

model User {
  id                String               @id @default(cuid())
  email             String               @unique
  passwordHash      String
  role              String
  slug              String?              @unique
  createdAt         DateTime             @default(now())

  properties        Property[]
  comments          RequestComment[]
  submittedRequests MaintenanceRequest[] @relation("SubmittedRequests")
  statusEvents      StatusEvent[]        @relation("StatusActor")
  dispatchEvents    VendorDispatchEvent[]
}

model Property {
  id        String   @id @default(cuid())
  ownerId   String
  name      String
  address   String
  createdAt DateTime @default(now())

  owner            User                 @relation(fields: [ownerId], references: [id])
  units            Unit[]
  requests         MaintenanceRequest[]
  tenantIdentities TenantIdentity[]
}

model Unit {
  id          String   @id @default(cuid())
  propertyId  String
  label       String
  tenantName  String?
  tenantEmail String?
  createdAt   DateTime @default(now())

  property         Property             @relation(fields: [propertyId], references: [id])
  requests         MaintenanceRequest[]
  tenantIdentities TenantIdentity[]
}

model MaintenanceRequest {
  id                    String             @id @default(cuid())
  propertyId            String
  unitId                String
  orgId                 String?
  tenantIdentityId      String?
  submittedByUserId     String?
  submittedByName       String?
  submittedByEmail      String?
  preferredCurrency     CurrencyOption     @default(usd)
  preferredLanguage     LanguageOption     @default(english)
  title                 String
  description           String
  category              String
  urgency               Urgency
  status                RequestStatus      @default(new)
  assignedVendorId      String?
  assignedVendorName    String?
  assignedVendorEmail   String?
  assignedVendorPhone   String?
  dispatchStatus        DispatchStatus?
  vendorScheduledStart  DateTime?
  vendorScheduledEnd    DateTime?
  reviewState           String?            @default("none")
  reviewNote            String?
  autoFlag              String?
  autoFlaggedAt         DateTime?
  lastAutoAlertAt       DateTime?
  slaBucket             String?            @default("standard")
  triageTagsCsv         String?            @default("")
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  closedAt              DateTime?

  property          Property             @relation(fields: [propertyId], references: [id])
  unit              Unit                 @relation(fields: [unitId], references: [id])
  tenantIdentity    TenantIdentity?      @relation(fields: [tenantIdentityId], references: [id])
  submittedByUser   User?                @relation("SubmittedRequests", fields: [submittedByUserId], references: [id])
  assignedVendor    Vendor?              @relation(fields: [assignedVendorId], references: [id])
  photos            MaintenancePhoto[]
  comments          RequestComment[]
  events            StatusEvent[]
  dispatchHistory   VendorDispatchEvent[]
  dispatchLinks     VendorDispatchLink[]

  @@index([tenantIdentityId])
  @@index([orgId])
}

model Vendor {
  id                    String               @id @default(cuid())
  orgId                 String?
  name                  String
  email                 String?
  phone                 String?
  categoriesCsv         String?              @default("")
  supportedLanguagesCsv String?              @default("")
  supportedCurrenciesCsv String?             @default("")
  isActive              Boolean              @default(true)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  assignedRequests      MaintenanceRequest[]
  dispatchEvents        VendorDispatchEvent[]
  dispatchLinks         VendorDispatchLink[]

  @@index([orgId, isActive])
}

model VendorDispatchEvent {
  id                String          @id @default(cuid())
  requestId         String
  vendorId          String?
  actorUserId       String?
  status            DispatchStatus
  note              String?
  scheduledStart    DateTime?
  scheduledEnd      DateTime?
  createdAt         DateTime        @default(now())

  request           MaintenanceRequest @relation(fields: [requestId], references: [id])
  vendor            Vendor?            @relation(fields: [vendorId], references: [id])
  actorUser         User?              @relation(fields: [actorUserId], references: [id])
  photos            MaintenancePhoto[]

  @@index([requestId, createdAt])
}

model VendorDispatchLink {
  id          String        @id @default(cuid())
  requestId   String
  vendorId    String
  tokenHash   String        @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime      @default(now())

  request     MaintenanceRequest @relation(fields: [requestId], references: [id])
  vendor      Vendor             @relation(fields: [vendorId], references: [id])

  @@index([requestId, vendorId])
}

model MaintenancePhoto {
  id                   String               @id @default(cuid())
  requestId            String
  dispatchEventId      String?
  imageUrl             String
  source               PhotoSource          @default(tenant)
  sourceLabel          String?
  createdAt            DateTime             @default(now())

  request              MaintenanceRequest   @relation(fields: [requestId], references: [id])
  dispatchEvent        VendorDispatchEvent? @relation(fields: [dispatchEventId], references: [id])
}

model RequestComment {
  id           String   @id @default(cuid())
  requestId    String
  authorUserId String?
  body         String
  visibility   String   @default("external")
  createdAt    DateTime @default(now())

  request MaintenanceRequest @relation(fields: [requestId], references: [id])
  author  User?              @relation(fields: [authorUserId], references: [id])
}

model StatusEvent {
  id          String                @id @default(cuid())
  requestId   String
  fromStatus  RequestStatus?
  toStatus    RequestStatus
  actorUserId String?
  visibility  TenantEventVisibility @default(tenant_visible)
  createdAt   DateTime              @default(now())

  request   MaintenanceRequest @relation(fields: [requestId], references: [id])
  actorUser User?              @relation("StatusActor", fields: [actorUserId], references: [id])
}

model TenantIdentity {
  id            String               @id @default(cuid())
  orgId         String
  propertyId    String
  unitId        String
  tenantName    String
  phoneE164     String
  email         String?
  status        TenantIdentityStatus @default(pending_invite)
  verifiedAt    DateTime?
  lastLoginAt   DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  property  Property              @relation(fields: [propertyId], references: [id])
  unit      Unit                  @relation(fields: [unitId], references: [id])
  requests  MaintenanceRequest[]
  invites   TenantInvite[]
  otpChallenges TenantOtpChallenge[]
  sessions  TenantSession[]

  @@index([orgId])
  @@index([propertyId])
  @@index([unitId])
  @@unique([orgId, phoneE164, unitId])
}

model TenantInvite {
  id               String             @id @default(cuid())
  tenantIdentityId String
  orgId            String
  propertyId       String
  unitId           String
  tokenHash        String             @unique
  status           TenantInviteStatus @default(pending)
  expiresAt        DateTime
  sentVia          TenantOtpChannel
  sentTo           String
  createdAt        DateTime           @default(now())
  acceptedAt       DateTime?
  revokedAt        DateTime?

  tenantIdentity TenantIdentity @relation(fields: [tenantIdentityId], references: [id])

  @@index([tenantIdentityId, status])
  @@index([orgId, status])
}

model TenantOtpChallenge {
  id               String           @id @default(cuid())
  tenantIdentityId String
  orgId            String
  purpose          TenantOtpPurpose
  channel          TenantOtpChannel
  destinationMasked String
  codeHash         String
  codeSalt         String
  expiresAt        DateTime
  attemptCount     Int              @default(0)
  maxAttempts      Int              @default(5)
  lockedUntil      DateTime?
  verifiedAt       DateTime?
  createdAt        DateTime         @default(now())

  tenantIdentity TenantIdentity @relation(fields: [tenantIdentityId], references: [id])

  @@index([tenantIdentityId, purpose, createdAt])
  @@index([orgId, purpose])
}

model TenantSession {
  id               String   @id @default(cuid())
  tenantIdentityId String
  orgId            String
  propertyId       String
  unitId           String
  sessionSecretHash String  @unique
  issuedAt         DateTime @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?
  lastSeenAt       DateTime?
  userAgent        String?

  tenantIdentity TenantIdentity @relation(fields: [tenantIdentityId], references: [id])

  @@index([tenantIdentityId, revokedAt])
  @@index([orgId])
}
