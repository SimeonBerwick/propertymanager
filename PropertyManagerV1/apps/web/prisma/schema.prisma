generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum RequestStatus {
  requested
  approved
  declined
  vendor_selected
  scheduled
  in_progress
  completed
  closed
  canceled
  reopened
}

enum Urgency {
  low
  medium
  high
  urgent
}

enum CurrencyOption {
  usd
  peso
  pound
  euro
}

enum LanguageOption {
  english
  spanish
  french
}

enum TenantIdentityStatus {
  pending_invite
  active
  inactive
  moved_out
}

enum TenantInviteStatus {
  pending
  accepted
  expired
  revoked
}

enum TenantOtpPurpose {
  invite_login
  returning_login
}

enum TenantOtpChannel {
  sms
  email
}

enum TenantEventVisibility {
  internal
  tenant_visible
}

enum DispatchStatus {
  assigned
  contacted
  accepted
  scheduled
  in_progress
  completed
  declined
  canceled
}

enum ReviewStatus {
  none
  needs_follow_up
  vendor_update_pending_review
  vendor_completed_pending_review
  reassignment_needed
  vendor_declined_reassignment_needed
  approved
  reopened_after_review
}

enum TenantBillbackDecision {
  none
  bill_tenant
  waived
}

enum BidSource {
  vendor_submitted
  manager_entered
}

enum TenderStatus {
  open
  awarded
  canceled
  closed
}

enum TenderInviteStatus {
  invited
  viewed
  declined
  bid_submitted
  withdrawn
  awarded
  not_awarded
}

enum PhotoSource {
  tenant
  landlord
  vendor
}

enum BillingRecipientType {
  tenant
  vendor
}

enum BillingDocumentType {
  tenant_invoice
  vendor_remittance
}

enum BillingDocumentStatus {
  draft
  sent
  partial
  paid
  void
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  displayName  String?
  passwordHash String
  role         String
  slug         String?  @unique
  createdAt    DateTime @default(now())

  properties              Property[]
  comments                RequestComment[]
  submittedRequests       MaintenanceRequest[]  @relation("SubmittedRequests")
  tenantBillbackDecisions MaintenanceRequest[]  @relation("TenantBillbackDecider")
  statusEvents            StatusEvent[]         @relation("StatusActor")
  dispatchEvents          VendorDispatchEvent[]
  billingDocuments        BillingDocument[]
  billingEvents           BillingEvent[]
  auditLogs               AuditLog[]
}

model Property {
  id        String   @id @default(cuid())
  ownerId   String
  name      String
  address   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  owner            User                 @relation(fields: [ownerId], references: [id])
  units            Unit[]
  requests         MaintenanceRequest[]
  tenantIdentities TenantIdentity[]
}

model Unit {
  id          String   @id @default(cuid())
  propertyId  String
  label       String
  tenantName  String?
  tenantEmail String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  property         Property             @relation(fields: [propertyId], references: [id])
  requests         MaintenanceRequest[]
  tenantIdentities TenantIdentity[]
}

model MaintenanceRequest {
  id                            String                 @id @default(cuid())
  propertyId                    String
  unitId                        String
  orgId                         String?
  tenantIdentityId              String?
  submittedByUserId             String?
  submittedByName               String?
  submittedByEmail              String?
  preferredCurrency             CurrencyOption         @default(usd)
  preferredLanguage             LanguageOption         @default(english)
  title                         String
  description                   String
  category                      String
  urgency                       Urgency
  status                        RequestStatus          @default(requested)
  assignedVendorId              String?
  assignedVendorName            String?
  assignedVendorEmail           String?
  assignedVendorPhone           String?
  dispatchStatus                DispatchStatus?
  vendorScheduledStart          DateTime?
  vendorScheduledEnd            DateTime?
  reviewState                   ReviewStatus           @default(none)
  reviewNote                    String?
  declineReason                 String?
  actualCompletedAt             DateTime?
  tenantBillbackDecision        TenantBillbackDecision @default(none)
  tenantBillbackAmountCents     Int                    @default(0)
  tenantBillbackReason          String?
  tenantBillbackDecidedAt       DateTime?
  tenantBillbackDecidedByUserId String?
  canceledByType                String?
  canceledByUserId              String?
  cancelReason                  String?
  reopenedReason                String?
  autoFlag                      String?
  autoFlaggedAt                 DateTime?
  lastAutoAlertAt               DateTime?
  firstReviewedAt               DateTime?
  claimedAt                     DateTime?
  claimedByUserId               String?
  slaBucket                     String?                @default("standard")
  triageTagsCsv                 String?                @default("")
  createdAt                     DateTime               @default(now())
  updatedAt                     DateTime               @updatedAt
  closedAt                      DateTime?

  property                Property              @relation(fields: [propertyId], references: [id])
  unit                    Unit                  @relation(fields: [unitId], references: [id])
  tenantIdentity          TenantIdentity?       @relation(fields: [tenantIdentityId], references: [id])
  submittedByUser         User?                 @relation("SubmittedRequests", fields: [submittedByUserId], references: [id])
  tenantBillbackDecidedBy User?                 @relation("TenantBillbackDecider", fields: [tenantBillbackDecidedByUserId], references: [id])
  assignedVendor          Vendor?               @relation(fields: [assignedVendorId], references: [id])
  photos                  MaintenancePhoto[]
  comments                RequestComment[]
  events                  StatusEvent[]
  dispatchHistory         VendorDispatchEvent[]
  dispatchLinks           VendorDispatchLink[]
  tenders                 RequestTender[]
  tenderInvites           TenderInvite[]
  billingDocuments        BillingDocument[]

  @@index([tenantIdentityId])
  @@index([orgId])
}

model RequestTender {
  id         String       @id @default(cuid())
  requestId  String
  status     TenderStatus @default(open)
  title      String?
  note       String?
  sentAt     DateTime?
  awardedAt  DateTime?
  canceledAt DateTime?
  closedAt   DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  request MaintenanceRequest @relation(fields: [requestId], references: [id])
  invites TenderInvite[]

  @@index([requestId, status])
}

model TenderInvite {
  id               String             @id @default(cuid())
  tenderId         String
  requestId        String
  vendorId         String
  status           TenderInviteStatus @default(invited)
  message          String?
  scopeNote        String?
  bidAmountCents   Int?
  bidCurrency      CurrencyOption?
  bidSource        BidSource?
  availabilityNote String?
  proposedStart    DateTime?
  proposedEnd      DateTime?
  invitedAt        DateTime           @default(now())
  viewedAt         DateTime?
  respondedAt      DateTime?
  awardedAt        DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  tender        RequestTender        @relation(fields: [tenderId], references: [id])
  request       MaintenanceRequest   @relation(fields: [requestId], references: [id])
  vendor        Vendor               @relation(fields: [vendorId], references: [id])
  dispatchLinks VendorDispatchLink[]

  @@unique([tenderId, vendorId])
  @@index([requestId, status])
  @@index([vendorId, status])
}

model Vendor {
  id                     String   @id @default(cuid())
  orgId                  String?
  name                   String
  email                  String?
  phone                  String?
  categoriesCsv          String?  @default("")
  supportedLanguagesCsv  String?  @default("")
  supportedCurrenciesCsv String?  @default("")
  isActive               Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  assignedRequests MaintenanceRequest[]
  dispatchEvents   VendorDispatchEvent[]
  dispatchLinks    VendorDispatchLink[]
  tenderInvites    TenderInvite[]

  @@index([orgId, isActive])
}

model VendorDispatchEvent {
  id             String         @id @default(cuid())
  requestId      String
  vendorId       String?
  actorUserId    String?
  status         DispatchStatus
  note           String?
  scheduledStart DateTime?
  scheduledEnd   DateTime?
  createdAt      DateTime       @default(now())

  request   MaintenanceRequest @relation(fields: [requestId], references: [id])
  vendor    Vendor?            @relation(fields: [vendorId], references: [id])
  actorUser User?              @relation(fields: [actorUserId], references: [id])
  photos    MaintenancePhoto[]

  @@index([requestId, createdAt])
}

model VendorDispatchLink {
  id             String    @id @default(cuid())
  requestId      String
  vendorId       String
  tenderInviteId String?
  tokenHash      String    @unique
  expiresAt      DateTime
  revokedAt      DateTime?
  lastUsedAt     DateTime?
  createdAt      DateTime  @default(now())

  request      MaintenanceRequest @relation(fields: [requestId], references: [id])
  vendor       Vendor             @relation(fields: [vendorId], references: [id])
  tenderInvite TenderInvite?      @relation(fields: [tenderInviteId], references: [id])

  @@index([requestId, vendorId])
}

model MaintenancePhoto {
  id              String      @id @default(cuid())
  requestId       String
  dispatchEventId String?
  imageUrl        String
  source          PhotoSource @default(tenant)
  sourceLabel     String?
  createdAt       DateTime    @default(now())

  request       MaintenanceRequest   @relation(fields: [requestId], references: [id])
  dispatchEvent VendorDispatchEvent? @relation(fields: [dispatchEventId], references: [id])
}

model RequestComment {
  id           String   @id @default(cuid())
  requestId    String
  authorUserId String?
  body         String
  visibility   String   @default("external")
  createdAt    DateTime @default(now())

  request MaintenanceRequest @relation(fields: [requestId], references: [id])
  author  User?              @relation(fields: [authorUserId], references: [id])
}

model StatusEvent {
  id          String                @id @default(cuid())
  requestId   String
  fromStatus  RequestStatus?
  toStatus    RequestStatus
  actorUserId String?
  visibility  TenantEventVisibility @default(tenant_visible)
  createdAt   DateTime              @default(now())

  request   MaintenanceRequest @relation(fields: [requestId], references: [id])
  actorUser User?              @relation("StatusActor", fields: [actorUserId], references: [id])
}

model TenantIdentity {
  id          String               @id @default(cuid())
  orgId       String
  propertyId  String
  unitId      String
  tenantName  String
  phoneE164   String
  email       String?
  status      TenantIdentityStatus @default(pending_invite)
  verifiedAt  DateTime?
  lastLoginAt DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  property      Property             @relation(fields: [propertyId], references: [id])
  unit          Unit                 @relation(fields: [unitId], references: [id])
  requests      MaintenanceRequest[]
  invites       TenantInvite[]
  otpChallenges TenantOtpChallenge[]
  sessions      TenantSession[]

  @@unique([orgId, phoneE164, unitId])
  @@index([orgId])
  @@index([propertyId])
  @@index([unitId])
}

model TenantInvite {
  id               String             @id @default(cuid())
  tenantIdentityId String
  orgId            String
  propertyId       String
  unitId           String
  tokenHash        String             @unique
  status           TenantInviteStatus @default(pending)
  expiresAt        DateTime
  sentVia          TenantOtpChannel
  sentTo           String
  createdAt        DateTime           @default(now())
  acceptedAt       DateTime?
  revokedAt        DateTime?

  tenantIdentity TenantIdentity @relation(fields: [tenantIdentityId], references: [id])

  @@index([tenantIdentityId, status])
  @@index([orgId, status])
}

model TenantOtpChallenge {
  id                String           @id @default(cuid())
  tenantIdentityId  String
  orgId             String
  purpose           TenantOtpPurpose
  channel           TenantOtpChannel
  destinationMasked String
  codeHash          String
  codeSalt          String
  expiresAt         DateTime
  attemptCount      Int              @default(0)
  maxAttempts       Int              @default(5)
  lockedUntil       DateTime?
  verifiedAt        DateTime?
  createdAt         DateTime         @default(now())

  tenantIdentity TenantIdentity @relation(fields: [tenantIdentityId], references: [id])

  @@index([tenantIdentityId, purpose, createdAt])
  @@index([orgId, purpose])
}

model TenantSession {
  id                String    @id @default(cuid())
  tenantIdentityId  String
  orgId             String
  propertyId        String
  unitId            String
  sessionSecretHash String    @unique
  issuedAt          DateTime  @default(now())
  expiresAt         DateTime
  revokedAt         DateTime?
  lastSeenAt        DateTime?
  userAgent         String?

  tenantIdentity TenantIdentity @relation(fields: [tenantIdentityId], references: [id])

  @@index([tenantIdentityId, revokedAt])
  @@index([orgId])
}

model BillingDocument {
  id              String                @id @default(cuid())
  requestId       String
  recipientType   BillingRecipientType
  documentType    BillingDocumentType
  status          BillingDocumentStatus @default(draft)
  currency        CurrencyOption        @default(usd)
  totalCents      Int
  paidCents       Int                   @default(0)
  title           String
  description     String?
  pdfUrl          String?
  sentTo          String?
  sentAt          DateTime?
  createdByUserId String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  request       MaintenanceRequest @relation(fields: [requestId], references: [id])
  createdByUser User?              @relation(fields: [createdByUserId], references: [id])
  events        BillingEvent[]

  @@index([requestId])
  @@index([status])
}

model BillingEvent {
  id                String   @id @default(cuid())
  billingDocumentId String
  actorUserId       String?
  eventType         String
  note              String?
  createdAt         DateTime @default(now())

  billingDocument BillingDocument @relation(fields: [billingDocumentId], references: [id])
  actorUser       User?           @relation(fields: [actorUserId], references: [id])

  @@index([billingDocumentId, createdAt])
}

model AuditLog {
  id           String   @id @default(cuid())
  orgId        String?
  actorUserId  String?
  entityType   String
  entityId     String
  action       String
  summary      String
  metadataJson String?
  createdAt    DateTime @default(now())

  actorUser User? @relation(fields: [actorUserId], references: [id])

  @@index([orgId, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
}
