generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // directUrl is required when DATABASE_URL uses Neon's pgbouncer pooler
  // (?pgbouncer=true). Set DATABASE_DIRECT_URL to the non-pooled connection
  // string so that `prisma migrate deploy` bypasses the pooler.
  // For local dev or non-pooled setups, set it to the same value as DATABASE_URL.
  directUrl = env("DATABASE_DIRECT_URL")
}

enum UserRole {
  OPERATOR
  TENANT
  VENDOR
}

enum InviteType {
  TENANT
  VENDOR
}

enum InviteStatus {
  ACTIVE
  USED
  EXPIRED
  REVOKED
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  FORMER
}

enum RequestCategory {
  PLUMBING
  ELECTRICAL
  HVAC
  APPLIANCE
  GENERAL
  OTHER
}

enum RequestUrgency {
  LOW
  MEDIUM
  HIGH
  EMERGENCY
}

enum RequestStatus {
  NEW
  SCHEDULED
  IN_PROGRESS
  DONE
}

enum RequestEventType {
  STATUS_CHANGED
  COMMENT
  VENDOR_ASSIGNED
  SCHEDULE_SET
  TENANT_UPDATE
}

enum EventVisibility {
  INTERNAL
  TENANT
  VENDOR
  ALL
}

enum VendorResponseStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum VendorPricingType {
  NONE
  FULL_BID
  INITIAL_SERVICE_FEE
}

model Organization {
  id                 String               @id @default(cuid())
  name               String
  createdAt          DateTime             @default(now())
  users              AppUser[]
  regions            Region[]
  properties         Property[]
  vendors            Vendor[]
  invites            Invite[]
  tenantIdentities   TenantIdentity[]
  tenantInvites      TenantInvite[]
  tenantOtpChallenges TenantOtpChallenge[]
  tenantSessions     TenantSession[]

  @@index([createdAt])
}

model Region {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  slug           String?
  notes          String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  properties     Property[]

  @@unique([organizationId, name])
  @@unique([organizationId, slug])
  @@index([organizationId, createdAt])
}

model AppUser {
  id                    String         @id @default(cuid())
  organizationId        String
  email                 String         @unique
  passwordHash          String
  name                  String
  role                  UserRole
  createdAt             DateTime       @default(now())
  organization          Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requestEvents         RequestEvent[]
  invitesCreated        Invite[]
  tenantInvitesCreated  TenantInvite[]

  @@index([organizationId, role])
}

model Property {
  id               String               @id @default(cuid())
  organizationId   String
  regionId         String?
  name             String
  addressLine1     String
  addressLine2     String?
  city             String
  state            String
  postalCode       String
  notes            String?
  createdAt        DateTime             @default(now())
  organization     Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  region           Region?              @relation(fields: [regionId], references: [id], onDelete: SetNull)
  units            Unit[]
  requests         MaintenanceRequest[]
  invites          Invite[]
  tenantIdentities TenantIdentity[]

  @@index([organizationId, regionId, createdAt])
}

model Unit {
  id               String               @id @default(cuid())
  propertyId       String
  label            String
  bedroomCount     Int?
  bathroomCount    Float?
  occupancyStatus  String?
  createdAt        DateTime             @default(now())
  property         Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenants          Tenant[]
  requests         MaintenanceRequest[]
  invites          Invite[]
  tenantIdentities TenantIdentity[]

  @@unique([propertyId, label])
  @@index([propertyId, createdAt])
}

model Tenant {
  id             String               @id @default(cuid())
  unitId         String
  name           String
  email          String?              @unique
  passwordHash   String?
  phone          String?
  status         TenantStatus         @default(ACTIVE)
  createdAt      DateTime             @default(now())
  unit           Unit                 @relation(fields: [unitId], references: [id], onDelete: Cascade)
  requests       MaintenanceRequest[]
  invites        Invite[]
  tenantIdentity TenantIdentity?

  @@index([unitId, status])
}

model Vendor {
  id             String               @id @default(cuid())
  organizationId String
  name           String
  trade          String
  phone          String?
  email          String?              @unique
  passwordHash   String?
  notes          String?
  createdAt      DateTime             @default(now())
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requests       MaintenanceRequest[]
  invites        Invite[]

  @@index([organizationId, trade])
}

model MaintenanceRequest {
  id                          String               @id @default(cuid())
  propertyId                  String
  unitId                      String
  tenantId                    String?
  createdByRole               UserRole
  title                       String
  description                 String
  category                    RequestCategory
  urgency                     RequestUrgency
  status                      RequestStatus        @default(NEW)
  isTenantVisible             Boolean              @default(true)
  isVendorVisible             Boolean              @default(true)
  assignedVendorId            String?
  scheduledFor                DateTime?
  vendorResponseStatus        VendorResponseStatus @default(PENDING)
  vendorPlannedStartDate      DateTime?
  vendorExpectedCompletionDate DateTime?
  vendorPricingType           VendorPricingType    @default(NONE)
  vendorPriceCents            Int?
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt
  closedAt                    DateTime?
  property                    Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit             Unit            @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tenant           Tenant?         @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  assignedVendor   Vendor?         @relation(fields: [assignedVendorId], references: [id], onDelete: SetNull)
  events           RequestEvent[]
  attachments      Attachment[]

  @@index([propertyId, status, createdAt])
  @@index([unitId, status])
  @@index([tenantId])
  @@index([assignedVendorId])
}

model RequestEvent {
  id          String             @id @default(cuid())
  requestId   String
  type        RequestEventType
  actorRole   UserRole
  actorName   String?
  actorUserId String?
  body        String
  visibility  EventVisibility    @default(INTERNAL)
  createdAt   DateTime           @default(now())
  request     MaintenanceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  actorUser   AppUser?           @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([requestId, createdAt])
  @@index([actorUserId])
}

model Attachment {
  id           String             @id @default(cuid())
  requestId    String
  uploaderRole UserRole
  storagePath  String
  mimeType     String
  createdAt    DateTime           @default(now())
  request      MaintenanceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId, createdAt])
}

model Invite {
  id              String       @id @default(cuid())
  type            InviteType
  status          InviteStatus @default(ACTIVE)
  organizationId  String
  propertyId      String?
  unitId          String?
  tenantId        String?
  vendorId        String?
  email           String?
  tokenHash       String       @unique
  expiresAt       DateTime
  usedAt          DateTime?
  revokedAt       DateTime?
  createdAt       DateTime     @default(now())
  createdByUserId String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property        Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  unit            Unit?        @relation(fields: [unitId], references: [id], onDelete: SetNull)
  tenant          Tenant?      @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  vendor          Vendor?      @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  createdByUser   AppUser      @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([organizationId, type, status])
  @@index([tenantId, status])
  @@index([vendorId, status])
  @@index([expiresAt])
}

// ─── Tenant Mobile Access ────────────────────────────────────────────────────

enum TenantIdentityStatus {
  PENDING_INVITE
  ACTIVE
  INACTIVE
  MOVED_OUT
}

enum TenantInviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum TenantInviteSentVia {
  SMS
  EMAIL
  MANUAL
}

enum TenantOtpPurpose {
  INVITE_LOGIN
  RETURNING_LOGIN
}

enum TenantOtpChannel {
  SMS
  EMAIL
}

model TenantIdentity {
  id              String               @id @default(cuid())
  orgId           String
  tenantId        String               @unique
  propertyId      String
  unitId          String
  phoneE164       String
  emailNormalized String?
  status          TenantIdentityStatus @default(PENDING_INVITE)
  verifiedAt      DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  organization    Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property        Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit            Unit                 @relation(fields: [unitId], references: [id], onDelete: Cascade)
  invites         TenantInvite[]
  otpChallenges   TenantOtpChallenge[]
  sessions        TenantSession[]

  @@index([orgId, status])
  @@index([phoneE164])
  @@index([emailNormalized])
}

model TenantInvite {
  id               String             @id @default(cuid())
  orgId            String
  tenantIdentityId String
  tenantId         String
  propertyId       String
  unitId           String
  tokenHash        String             @unique
  status           TenantInviteStatus @default(PENDING)
  expiresAt        DateTime
  sentVia          TenantInviteSentVia
  sentTo           String
  createdByUserId  String
  acceptedAt       DateTime?
  revokedAt        DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  organization     Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tenantIdentity   TenantIdentity     @relation(fields: [tenantIdentityId], references: [id], onDelete: Cascade)
  createdByUser    AppUser            @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([orgId, status])
  @@index([tenantIdentityId, status])
  @@index([expiresAt])
}

model TenantOtpChallenge {
  id                String           @id @default(cuid())
  orgId             String
  tenantIdentityId  String
  purpose           TenantOtpPurpose
  channel           TenantOtpChannel
  destinationMasked String
  codeHash          String
  expiresAt         DateTime
  attemptCount      Int              @default(0)
  maxAttempts       Int              @default(5)
  lockedUntil       DateTime?
  verifiedAt        DateTime?
  createdAt         DateTime         @default(now())

  organization      Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tenantIdentity    TenantIdentity   @relation(fields: [tenantIdentityId], references: [id], onDelete: Cascade)

  @@index([tenantIdentityId, createdAt])
  @@index([expiresAt])
}

model TenantSession {
  id                String         @id @default(cuid())
  orgId             String
  tenantIdentityId  String
  tenantId          String
  propertyId        String
  unitId            String
  sessionSecretHash String         @unique
  issuedAt          DateTime       @default(now())
  expiresAt         DateTime
  revokedAt         DateTime?
  lastSeenAt        DateTime?
  ipHash            String?
  userAgent         String?

  organization      Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tenantIdentity    TenantIdentity @relation(fields: [tenantIdentityId], references: [id], onDelete: Cascade)

  @@index([tenantIdentityId, revokedAt, expiresAt])
  @@index([orgId])
}
