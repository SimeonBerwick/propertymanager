{
  "name": "property-manager",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:invites && npm run test:attachments && npm run test:phone && npm run test:vendor && npm run test:auth-runtime && npm run test:authz && npm run test:e2e:smoke",
    "test:auth-runtime": "node --import tsx --test tests/auth-runtime.test.ts",
    "test:authz": "node --import tsx --test tests/auth-boundaries.test.ts",
    "test:invites": "node --import tsx --test tests/invites.test.ts",
    "test:attachments": "node --import tsx --test tests/request-attachments.test.ts",
    "test:phone": "node --import tsx --test tests/phone-parsing.test.ts",
    "test:vendor": "node --import tsx --test tests/vendor-management.test.ts",
    "test:e2e:smoke": "node --import tsx --test tests/e2e-smoke.test.ts",
    "prisma:generate": "prisma generate",
    "prisma:db:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:setup": "npm run prisma:generate && npm run prisma:db:push && npm run prisma:seed",
    "validate": "npm run typecheck && npm run lint && npm run test:invites && npm run test:attachments && npm run test:phone && npm run test:vendor"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@prisma/client": "^6.5.0",
    "libphonenumber-js": "^1.12.40",
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.21.0",
    "eslint-config-next": "^15.2.0",
    "postcss": "^8.5.3",
    "prisma": "^6.5.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "undici": "^7.16.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
