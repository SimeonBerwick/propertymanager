# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (SQLite):
DATABASE_URL="file:./prisma/dev.db"
# Production (Neon Postgres — pooled connection string):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
#
# If using Neon's connection pooler (pgbouncer), also set DATABASE_DIRECT_URL
# to the non-pooled connection string so that Prisma migrations work correctly.
# (Add `directUrl = env("DATABASE_DIRECT_URL")` to prisma/schema.prisma datasource)
# DATABASE_DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Required in production. Must be >= 32 chars and NOT the demo placeholder.
# Generate with: openssl rand -base64 48
AUTH_SECRET="change-this-demo-secret-before-sharing"

# ── App URL ───────────────────────────────────────────────────────────────────
# Used to build absolute invite links delivered to tenants.
# Local dev:
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Production:
# NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# ── Storage ───────────────────────────────────────────────────────────────────
# STORAGE_PROVIDER=local  -> files written to public/uploads/ (dev only)
# STORAGE_PROVIDER=r2     -> files stored in Cloudflare R2 (REQUIRED for production)
#
# WARNING: local storage uses the server's filesystem, which is ephemeral on
# platforms like Vercel. Any upload will be lost on the next deployment.
# Always use STORAGE_PROVIDER=r2 in production.
STORAGE_PROVIDER=local

# Cloudflare R2 -- required when STORAGE_PROVIDER=r2
# R2_ACCOUNT_ID=""
# R2_BUCKET=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""

# ── Node environment ──────────────────────────────────────────────────────────
# Set to "production" in Vercel / hosting environment. Controls:
#   - cookie secure flag
#   - AUTH_SECRET demo-fallback guard
#   - OTP dev-mode display
#   - local storage guard (storagePut throws if STORAGE_PROVIDER=local in prod)
NODE_ENV=development

# ── Optional ─────────────────────────────────────────────────────────────────
# SEED_ALLOWED=false        (prevent seed endpoint in production)
# LOG_LEVEL=info
# SENTRY_DSN=""
# SENTRY_ENVIRONMENT=""
