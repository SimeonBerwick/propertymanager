# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (local PostgreSQL, non-pooled — both vars point to the same URL):
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/property_manager"
DATABASE_DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/property_manager"
#
# Production (Neon Postgres — pgbouncer pooled):
#   DATABASE_URL     → pooled connection string (pgbouncer, used by Prisma Client)
#   DATABASE_DIRECT_URL → non-pooled connection string (used by prisma migrate deploy)
#   If NOT using Neon's connection pooler, both values can be the same URL.
#
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-yyy.us-east-2.aws.neon.tech/neondb?pgbouncer=true&connection_limit=1&pool_timeout=0&sslmode=require"
# DATABASE_DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx-yyy.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Required in production. Must be >= 32 chars and NOT the demo placeholder.
# Generate with: openssl rand -base64 48
AUTH_SECRET="change-this-demo-secret-before-sharing"

# ── App URL ───────────────────────────────────────────────────────────────────
# Used to build absolute invite links delivered to tenants.
# Must use HTTPS in production. Invite tokens are single-use and expire in 7 days.
# Local dev:
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Production:
# NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# ── Storage ───────────────────────────────────────────────────────────────────
# STORAGE_PROVIDER=local  -> files written to public/uploads/ (dev only)
# STORAGE_PROVIDER=r2     -> files stored in Cloudflare R2 (REQUIRED for production)
#
# WARNING: local storage uses the server's filesystem, which is ephemeral on
# platforms like Vercel. Any upload will be lost on the next deployment.
# Always use STORAGE_PROVIDER=r2 in production.
STORAGE_PROVIDER=local

# Cloudflare R2 -- required when STORAGE_PROVIDER=r2
# R2_ACCOUNT_ID=""
# R2_BUCKET=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""

# ── Node environment ──────────────────────────────────────────────────────────
# Set to "production" in Vercel / hosting environment. Controls:
#   - cookie secure flag
#   - AUTH_SECRET demo-fallback guard
#   - OTP dev-mode code display (suppressed in production)
#   - local storage guard (storagePut throws if STORAGE_PROVIDER=local in prod)
NODE_ENV=development

# ── Seed / demo data ──────────────────────────────────────────────────────────
# SEED_ALLOWED=false prevents `prisma db seed` from wiping data in production.
# The seed script checks NODE_ENV=production + SEED_ALLOWED != "true" and exits.
# Never set SEED_ALLOWED=true in a production environment.
SEED_ALLOWED=false

# ── OTP transport (V1 notice) ─────────────────────────────────────────────────
# V1 does not include an integrated SMS/email transport for OTP delivery.
# In development, the raw OTP code is shown in-browser (NODE_ENV != production only).
# In production, wire up delivery BEFORE enabling tenant mobile access:
#   app/mobile/auth/accept/[token]/page.tsx → call Twilio/Resend with otp.rawCode
#   after createOtpChallenge(). Never log rawCode.

# ── Optional ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=info
# SENTRY_DSN=""
# SENTRY_ENVIRONMENT=""
