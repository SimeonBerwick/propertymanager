# Primary app database (Neon Postgres in hosted environments)
# Example local Postgres:
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/propertymanager_dev?schema=public"
# Example Neon pooled URL:
# DATABASE_URL="postgresql://user:pass@ep-xxxx.us-east-1.aws.neon.tech/propertymanager?sslmode=require&channel_binding=require"
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/propertymanager_dev?schema=public"

# Optional test/e2e DB URLs.
# Recommended local pattern: one Postgres database, separate schemas.
TEST_DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/propertymanager_dev?schema=test"
E2E_DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/propertymanager_dev?schema=e2e"

# Session encryption key — must be at least 32 characters in production
# Generate with: openssl rand -hex 32
SESSION_SECRET="your-secret-here-must-be-at-least-32-characters-long"

# Landlord identity — used to seed the landlord user into the DB and as a dev fallback
# In production: set both, run `prisma db seed` to write hashed credentials to DB, then
# the app authenticates against the DB. LANDLORD_PASSWORD is cleartext only at seed time.
# Dev default (no env): landlord@example.com / changeme (never used in production)
LANDLORD_EMAIL="landlord@example.com"
LANDLORD_PASSWORD="changeme"

# Public URL slug for the tenant submission form: /submit/[LANDLORD_SLUG]
# If unset, the slug is derived from the email prefix (e.g. landlord@example.com → "landlord").
# Allowed characters: a-z, 0-9, hyphens.
# LANDLORD_SLUG="my-properties"

# Hosted production targets
# - Media: Cloudflare R2 (migration still in progress)
# - Shared rate limiting: Upstash Redis (migration still in progress)
# Remaining local-disk / in-memory behavior is temporary and should not be treated as the end-state architecture.
# R2_ACCOUNT_ID="..."
# R2_ACCESS_KEY_ID="..."
# R2_SECRET_ACCESS_KEY="..."
# R2_BUCKET="propertymanager-media"
# R2_PUBLIC_BASE_URL="https://<bucket>.<account>.r2.cloudflarestorage.com"
# UPSTASH_REDIS_REST_URL="https://..."
# UPSTASH_REDIS_REST_TOKEN="..."

# ── Email notifications ────────────────────────────────────────────────────────
# NOTIFY_TRANSPORT controls where outbound email notifications go.
#
#   unset / "log" (default) — prints to stdout; safe for local dev, zero config.
#   "smtp"                  — sends real email via nodemailer.
#                             Requires SMTP_URL (standard connection string).
#
# SMTP connection string examples:
#   smtp://user:pass@smtp.example.com:587          (STARTTLS)
#   smtps://user:pass@smtp.example.com:465         (TLS)
#   smtp://localhost:1025                           (MailHog / local catcher)
#   smtps://apikey:<SENDGRID_KEY>@smtp.sendgrid.net:465
#   smtps://resend:<RESEND_API_KEY>@smtp.resend.com:465
#
# NOTIFY_FROM sets the From address (defaults to noreply@propertymanager.local).
#
# NOTIFY_TRANSPORT="smtp"
# SMTP_URL="smtp://user:pass@localhost:1025"
# NOTIFY_FROM="Property Manager <noreply@yourdomain.com>"

# ── SMS notifications ──────────────────────────────────────────────────────────
# SMS_TRANSPORT controls where outbound SMS messages go.
#
#   unset / "log" (default) — prints to stdout; safe for local dev, zero config.
#   "twilio"                — sends real SMS via Twilio REST API.
#                             Requires TWILIO_ACCOUNT_SID + TWILIO_AUTH_TOKEN,
#                             plus exactly one sender:
#                               TWILIO_FROM_NUMBER         — direct E.164 number
#                               TWILIO_MESSAGING_SERVICE_SID — Messaging Service SID
#
# SMS_TRANSPORT="twilio"
# TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# TWILIO_AUTH_TOKEN="your_auth_token_here"
# TWILIO_FROM_NUMBER="+15005550006"
# TWILIO_MESSAGING_SERVICE_SID="MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
