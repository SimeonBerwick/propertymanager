DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/propertymanager_dev?schema=public"

# Session encryption key — must be at least 32 characters in production
# Generate with: openssl rand -hex 32
# Companion-app / packaged deployments should always override this with a real secret.
SESSION_SECRET="your-secret-here-must-be-at-least-32-characters-long"

# Landlord identity — used to seed the landlord user into the DB and as a dev fallback
# In production: set both, run `prisma db seed` to write hashed credentials to DB, then
# the app authenticates against the DB. LANDLORD_PASSWORD is cleartext only at seed time.
# Dev default (no env): landlord@example.com / changeme (never used in production)
LANDLORD_EMAIL="landlord@example.com"
LANDLORD_PASSWORD="changeme"

# Google Play review demo access. These defaults only unlock the fixed
# play-review tenant/vendor/staff emails in lib/reviewer-access.ts.
ANDROID_REVIEWER_LANDLORD_PASSWORD="play-review-password-2026"
ANDROID_REVIEWER_OTP_CODE="424242"
ANDROID_REVIEWER_STAFF_EMAIL="play-review-staff@simeonware.com"

# Public URL slug for the tenant submission form: /submit/[LANDLORD_SLUG]
# If unset, the slug is derived from the email prefix (e.g. landlord@example.com → "landlord").
# Allowed characters: a-z, 0-9, hyphens.
# LANDLORD_SLUG="my-properties"

# Uploaded request photos are stored privately under ./uploads/requests and are
# served only through authenticated media routes. Do not point this at /public.
# Current auth rate limiting is process-memory based: good for single-node packaging,
# not sufficient as-is for horizontally scaled multi-instance deployment.

# ── Email notifications ────────────────────────────────────────────────────────
# NOTIFY_TRANSPORT controls where outbound email notifications go.
#
#   unset / "log" (default) — prints to stdout; safe for local dev, zero config.
#   "smtp"                  — sends real email via nodemailer.
#                             Requires SMTP_URL (standard connection string).
#
# SMTP connection string examples:
#   smtp://user:pass@smtp.example.com:587          (STARTTLS)
#   smtps://user:pass@smtp.example.com:465         (TLS)
#   smtp://localhost:1025                           (MailHog / local catcher)
#   smtps://apikey:<SENDGRID_KEY>@smtp.sendgrid.net:465
#   smtps://resend:<RESEND_API_KEY>@smtp.resend.com:465
#
# NOTIFY_FROM sets the From address (defaults to noreply@propertymanager.local).
#
# NOTIFY_TRANSPORT="smtp"
# SMTP_URL="smtp://user:pass@localhost:1025"
# NOTIFY_FROM="Property Manager <noreply@yourdomain.com>"

# Android App Links verification for /.well-known/assetlinks.json.
# Use the Android applicationId/package name and Play App Signing SHA-256
# certificate fingerprint. Multiple fingerprints may be comma-separated.
ANDROID_APP_PACKAGE_NAME="com.example.propertymanager"
ANDROID_APP_SHA256_CERT_FINGERPRINTS="AA:BB:CC:DD:EE:FF"

# Web push notifications. Generate a key pair with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# VAPID_SUBJECT="mailto:notifications@simeonware.com"

# Optional landlord-connected mailbox OAuth.
# When connected from the dashboard and email notifications are On, outbound
# ticket mail uses the landlord mailbox and replies can sync back into requests.
# MAILBOX_TOKEN_ENCRYPTION_KEY should be a random value at least 32 characters.
# MAILBOX_TOKEN_ENCRYPTION_KEY="replace-with-a-random-secret-at-least-32-characters"
# GMAIL_OAUTH_CLIENT_ID=""
# GMAIL_OAUTH_CLIENT_SECRET=""
# OUTLOOK_OAUTH_CLIENT_ID=""
# OUTLOOK_OAUTH_CLIENT_SECRET=""
# OUTLOOK_TENANT_ID="common"

# ── SMS / phone login (deferred from V1.0) ────────────────────────────────────
# V1.0 is email-only for tenant access. Do not treat SMS/Twilio as a launch
# dependency.
#
# When V1.1 adds phone-based tenant login after LLC/business setup, re-enable an
# SMS transport here (Twilio or another provider) and wire the phone login path
# back into the app.
# Optional recipient for hosted automation, mailbox, export, and subscription failure alerts.
OPS_ALERT_EMAIL=
GOOGLE_TRANSLATE_API_KEY=

# QuickBooks Online OAuth and signed webhooks.
# QUICKBOOKS_ENVIRONMENT="sandbox"
# QUICKBOOKS_CLIENT_ID=""
# QUICKBOOKS_CLIENT_SECRET=""
# QUICKBOOKS_REDIRECT_URI="https://www.simeonware.com/api/quickbooks/callback"
# QUICKBOOKS_WEBHOOK_VERIFIER_TOKEN=""
