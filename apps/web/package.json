{
  "name": "property-manager-v1-web",
  "private": true,
  "version": "0.1.0",
  "prisma": {
    "seed": "./node_modules/.bin/tsx prisma/seed.ts"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "vercel-build": "prisma migrate deploy && next build",
    "dev": "next dev",
    "dev:local": "SESSION_SECRET=${SESSION_SECRET:-local-dev-session-secret-2026-abcdef123456} LANDLORD_EMAIL=${LANDLORD_EMAIL:-landlord@example.com} LANDLORD_PASSWORD=${LANDLORD_PASSWORD:-changeme} next dev",
    "build": "next build",
    "start": "next start",
    "start:prod-local": "NODE_ENV=production SESSION_SECRET=${SESSION_SECRET:-local-dev-session-secret-2026-abcdef123456} LANDLORD_EMAIL=${LANDLORD_EMAIL:-landlord@example.com} LANDLORD_PASSWORD=${LANDLORD_PASSWORD:-local-prod-password-2026} next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "./node_modules/.bin/tsx prisma/seed.ts",
    "ops:sync-landlord-password": "node ./scripts/sync-landlord-password.mjs",
    "seed:android-reviewers": "tsx ./scripts/seed-android-reviewers.ts",
    "verify:android-reviewers": "tsx ./scripts/verify-android-reviewers.ts",
    "hosted:db:reconcile": "bash ./scripts/apply-hosted-postgres-reconciliation.sh",
    "setup:local": "npm run prisma:generate && npx prisma migrate deploy && npm run prisma:seed",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:watch": "vitest",
    "test:hosted": "node ./scripts/hosted-regression.mjs",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1040.0",
    "@prisma/client": "^6.9.0",
    "firebase-admin": "^14.0.0",
    "iron-session": "^8.0.4",
    "libphonenumber-js": "^1.12.40",
    "next": "^15.5.14",
    "nodemailer": "^9.0.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "stripe": "^22.2.0",
    "web-push": "^3.6.7"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.13.10",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "19.2.16",
    "@types/react-dom": "^19.0.4",
    "@types/web-push": "^3.6.4",
    "prisma": "^6.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.1"
  }
}
