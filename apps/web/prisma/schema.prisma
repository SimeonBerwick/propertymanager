generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RequestStatus {
  requested
  approved
  declined
  vendor_selected
  scheduled
  in_progress
  completed
  closed
  canceled
  reopened
}

enum Urgency {
  low
  medium
  high
  urgent
}

enum CurrencyOption {
  usd
  cad
  peso
  pound
  euro
  aud
}

enum LanguageOption {
  english
  spanish
  french
}

enum TenantIdentityStatus {
  pending_invite
  active
  inactive
  moved_out
}

enum TenantInviteStatus {
  pending
  accepted
  expired
  revoked
}

enum TenantOtpPurpose {
  invite_login
  returning_login
}

enum TenantOtpChannel {
  sms
  email
}

enum VendorOtpPurpose {
  returning_login
  dispatch_link_login
}

enum VendorOtpChannel {
  sms
  email
}

enum ManagerAccessCodeRole {
  tenant
  vendor
}

enum TenantEventVisibility {
  internal
  tenant_visible
}

enum DispatchStatus {
  assigned
  contacted
  accepted
  scheduled
  in_progress
  completed
  declined
  canceled
}

enum ReviewStatus {
  none
  needs_follow_up
  vendor_update_pending_review
  vendor_completed_pending_review
  reassignment_needed
  vendor_declined_reassignment_needed
  approved
  reopened_after_review
}

enum TenantBillbackDecision {
  none
  bill_tenant
  waived
}

enum BidSource {
  vendor_submitted
  manager_entered
}

enum TenderStatus {
  open
  awarded
  canceled
  closed
}

enum TenderInviteStatus {
  invited
  viewed
  declined
  bid_submitted
  withdrawn
  awarded
  not_awarded
}

enum PhotoSource {
  tenant
  landlord
  vendor
}

enum BillingRecipientType {
  tenant
  vendor
}

enum BillingDocumentType {
  tenant_invoice
  vendor_remittance
}

enum BillingDocumentStatus {
  draft
  sent
  partial
  paid
  void
}

enum AccountSubscriptionStatus {
  trialing
  active
  past_due
  canceled
  expired
}

enum AccountPlan {
  growth
  pro
  portfolio
}

enum BillingCadence {
  monthly
  annual
}

enum VendorCommercialType {
  bid
  service_fee
  overcost
  bill_to_property_manager
}

enum VendorCommercialStatus {
  submitted
  approved
  declined
}

enum MailboxProvider {
  gmail
  outlook
}

enum MailboxConnectionStatus {
  connected
  needs_reauth
  disconnected
}

enum EmailDeliveryStatus {
  pending
  sent
  failed
  received
  ignored
}

enum PropertyType {
  single_family
  multifamily
}

enum PropertyLocationType {
  residential
  common_area
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  displayName  String?
  businessName String?
  passwordHash String
  role         String
  slug         String?  @unique
  subscriptionStatus AccountSubscriptionStatus @default(trialing)
  subscriptionPlan   AccountPlan?
  billingCadence     BillingCadence?
  trialEndsAt        DateTime?
  subscriptionEndsAt DateTime?
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  defaultCurrency      CurrencyOption @default(usd)
  emailNotificationsEnabled Boolean @default(true)
  dailyBriefingEnabled Boolean @default(true)
  vendorRemindersEnabled Boolean @default(true)
  dailyCsvExportEnabled Boolean @default(false)
  dailyCsvExportLastSentAt DateTime?
  turnBoardStatusFilter String @default("active")
  turnBoardPropertyFilter String?
  createdAt    DateTime @default(now())

  properties              Property[]
  comments                RequestComment[]
  mailboxConnections      MailboxConnection[]
  outboundEmails          OutboundEmail[]
  inboundEmails           InboundEmail[]
  submittedRequests       MaintenanceRequest[]  @relation("SubmittedRequests")
  tenantBillbackDecisions MaintenanceRequest[]  @relation("TenantBillbackDecider")
  statusEvents            StatusEvent[]         @relation("StatusActor")
  dispatchEvents          VendorDispatchEvent[]
  billingDocuments        BillingDocument[]
  billingEvents           BillingEvent[]
  auditLogs               AuditLog[]
  accountDeletionRequests AccountDeletionRequest[]
}

model Property {
  id        String   @id @default(cuid())
  ownerId   String
  name      String
  address   String
  propertyType PropertyType @default(single_family)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner            User                 @relation(fields: [ownerId], references: [id])
  units            Unit[]
  requests         MaintenanceRequest[]
  tenantIdentities TenantIdentity[]
}

model Unit {
  id               String   @id @default(cuid())
  propertyId       String
  label            String
  locationType     PropertyLocationType @default(residential)
  areaType         String?
  city             String?
  state            String?
  tenantName       String?
  tenantEmail      String?
  sizeSqFt         Int?
  bedrooms         Int?
  bathrooms        Float?
  monthlyRentCents Int?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  property         Property             @relation(fields: [propertyId], references: [id])
  requests         MaintenanceRequest[]
  tenantIdentities TenantIdentity[]
  inspections      Inspection[]
  turns            UnitTurn[]

  @@index([propertyId, locationType, isActive])
}

model MaintenanceRequest {
  id                            String                 @id @default(cuid())
  propertyId                    String
  unitId                        String
  orgId                         String?
  tenantIdentityId              String?
  submittedByUserId             String?
  submittedByName               String?
  submittedByEmail              String?
  preferredCurrency             CurrencyOption         @default(usd)
  preferredLanguage             LanguageOption         @default(english)
  title                         String
  description                   String
  category                      String
  urgency                       Urgency
  status                        RequestStatus          @default(requested)
  assignedVendorId              String?
  assignedVendorName            String?
  assignedVendorEmail           String?
  assignedVendorPhone           String?
  dispatchStatus                DispatchStatus?
  vendorScheduledStart          DateTime?
  vendorScheduledEnd            DateTime?
  reviewState                   ReviewStatus           @default(none)
  reviewNote                    String?
  declineReason                 String?
  actualCompletedAt             DateTime?
  tenantBillbackDecision        TenantBillbackDecision @default(none)
  tenantBillbackAmountCents     Int                    @default(0)
  tenantBillbackReason          String?
  tenantBillbackDecidedAt       DateTime?
  tenantBillbackDecidedByUserId String?
  canceledByType                String?
  canceledByUserId              String?
  cancelReason                  String?
  reopenedReason                String?
  autoFlag                      String?
  autoFlaggedAt                 DateTime?
  lastAutoAlertAt               DateTime?
  vendorReminderEnabled         Boolean?
  lastVendorReminderAt          DateTime?
  firstReviewedAt               DateTime?
  claimedAt                     DateTime?
  claimedByUserId               String?
  slaBucket                     String?                @default("standard")
  triageTagsCsv                 String?                @default("")
  createdAt                     DateTime               @default(now())
  updatedAt                     DateTime               @updatedAt
  closedAt                      DateTime?

  property                Property              @relation(fields: [propertyId], references: [id])
  unit                    Unit                  @relation(fields: [unitId], references: [id])
  tenantIdentity          TenantIdentity?       @relation(fields: [tenantIdentityId], references: [id])
  submittedByUser         User?                 @relation("SubmittedRequests", fields: [submittedByUserId], references: [id])
  tenantBillbackDecidedBy User?                 @relation("TenantBillbackDecider", fields: [tenantBillbackDecidedByUserId], references: [id])
  assignedVendor          Vendor?               @relation(fields: [assignedVendorId], references: [id])
  photos                  MaintenancePhoto[]
  comments                RequestComment[]
  outboundEmails          OutboundEmail[]
  inboundEmails           InboundEmail[]
  events                  StatusEvent[]
  dispatchHistory         VendorDispatchEvent[]
  dispatchLinks           VendorDispatchLink[]
  tenders                 RequestTender[]
  tenderInvites           TenderInvite[]
  billingDocuments        BillingDocument[]
  vendorCommercialItems   VendorCommercialItem[]
  inspectionFindings      InspectionItem[]
  turnTasks               UnitTurnTask[]

  @@index([tenantIdentityId])
  @@index([orgId])
}

model InspectionTemplate {
  id                    String   @id @default(cuid())
  orgId                 String
  name                  String
  inspectionType        String
  checklistJson         String
  requirePhotoForIssues Boolean  @default(true)
  requireNoteForIssues  Boolean  @default(true)
  includePhotosInReport Boolean  @default(true)
  defaultDueDays        Int      @default(7)
  reportTitle           String   @default("Property inspection report")
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  inspections Inspection[]

  @@index([orgId, isActive])
}

model Inspection {
  id                    String   @id @default(cuid())
  orgId                 String
  unitId                String
  templateId            String?
  title                 String
  inspectionType        String
  templateName          String
  status                String   @default("draft")
  dueAt                 DateTime?
  completedAt           DateTime?
  requirePhotoForIssues Boolean  @default(true)
  requireNoteForIssues  Boolean  @default(true)
  includePhotosInReport Boolean  @default(true)
  reportTitle           String   @default("Property inspection report")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  unit     Unit                @relation(fields: [unitId], references: [id])
  template InspectionTemplate? @relation(fields: [templateId], references: [id])
  items    InspectionItem[]

  @@index([orgId, status, dueAt])
  @@index([unitId, createdAt])
}

model InspectionItem {
  id                   String   @id @default(cuid())
  inspectionId         String
  maintenanceRequestId String?
  section              String
  label                String
  position             Int
  result               String   @default("pending")
  note                 String?
  photoUrl             String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  inspection        Inspection         @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  maintenanceRequest MaintenanceRequest? @relation(fields: [maintenanceRequestId], references: [id])

  @@index([inspectionId, position])
  @@index([maintenanceRequestId])
}

model UnitTurnTemplate {
  id                        String   @id @default(cuid())
  orgId                     String
  name                      String
  tasksJson                 String
  defaultTargetDays         Int      @default(10)
  requirePhotoForCompletion Boolean  @default(false)
  requireNoteForCompletion  Boolean  @default(false)
  requireAllTasksForReady   Boolean  @default(true)
  isActive                  Boolean  @default(true)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  turns UnitTurn[]

  @@index([orgId, isActive])
}

model UnitTurn {
  id                        String   @id @default(cuid())
  orgId                     String
  unitId                    String
  templateId                String?
  title                     String
  templateName              String
  status                    String   @default("planned")
  moveOutAt                 DateTime
  targetMoveInAt            DateTime?
  readyAt                   DateTime?
  requirePhotoForCompletion Boolean  @default(false)
  requireNoteForCompletion  Boolean  @default(false)
  requireAllTasksForReady   Boolean  @default(true)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  unit     Unit              @relation(fields: [unitId], references: [id])
  template UnitTurnTemplate? @relation(fields: [templateId], references: [id])
  tasks    UnitTurnTask[]

  @@index([orgId, status, targetMoveInAt])
  @@index([unitId, createdAt])
}

model UnitTurnTask {
  id                   String   @id @default(cuid())
  turnId               String
  maintenanceRequestId String?
  assignedVendorId     String?
  title                String
  position             Int
  expectedDays         Int      @default(1)
  assignedType         String   @default("manager")
  status               String   @default("not_started")
  dueAt                DateTime?
  completedAt          DateTime?
  note                 String?
  photoUrl             String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  turn               UnitTurn           @relation(fields: [turnId], references: [id], onDelete: Cascade)
  maintenanceRequest MaintenanceRequest? @relation(fields: [maintenanceRequestId], references: [id])
  assignedVendor     Vendor?             @relation(fields: [assignedVendorId], references: [id])

  @@index([turnId, position])
  @@index([maintenanceRequestId])
  @@index([assignedVendorId, status])
}

model RequestTender {
  id         String       @id @default(cuid())
  requestId  String
  status     TenderStatus @default(open)
  title      String?
  note       String?
  sentAt     DateTime?
  awardedAt  DateTime?
  canceledAt DateTime?
  closedAt   DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  request MaintenanceRequest @relation(fields: [requestId], references: [id])
  invites TenderInvite[]

  @@index([requestId, status])
}

model TenderInvite {
  id               String             @id @default(cuid())
  tenderId         String
  requestId        String
  vendorId         String
  status           TenderInviteStatus @default(invited)
  message          String?
  scopeNote        String?
  bidAmountCents   Int?
  bidCurrency      CurrencyOption?
  bidSource        BidSource?
  availabilityNote String?
  proposedStart    DateTime?
  proposedEnd      DateTime?
  invitedAt        DateTime           @default(now())
  viewedAt         DateTime?
  respondedAt      DateTime?
  awardedAt        DateTime?
  lastVendorReminderAt DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  tender        RequestTender        @relation(fields: [tenderId], references: [id])
  request       MaintenanceRequest   @relation(fields: [requestId], references: [id])
  vendor        Vendor               @relation(fields: [vendorId], references: [id])
  dispatchLinks VendorDispatchLink[]

  @@unique([tenderId, vendorId])
  @@index([requestId, status])
  @@index([vendorId, status])
}

model Vendor {
  id                     String   @id @default(cuid())
  orgId                  String?
  name                   String
  email                  String?
  phone                  String?
  categoriesCsv          String?  @default("")
  supportedLanguagesCsv  String?  @default("")
  supportedCurrenciesCsv String?  @default("")
  isActive               Boolean  @default(true)
  lastLoginAt            DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  assignedRequests MaintenanceRequest[]
  dispatchEvents   VendorDispatchEvent[]
  dispatchLinks    VendorDispatchLink[]
  tenderInvites    TenderInvite[]
  sessions         VendorSession[]
  otpChallenges    VendorOtpChallenge[]
  commercialItems  VendorCommercialItem[]
  turnTasks         UnitTurnTask[]

  @@index([orgId, isActive])
  @@index([email, isActive])
}

model VendorCommercialItem {
  id           String                 @id @default(cuid())
  requestId    String
  vendorId     String
  orgId        String?
  itemType     VendorCommercialType
  status       VendorCommercialStatus @default(submitted)
  paymentTiming String                 @default("on_completion")
  currency     CurrencyOption         @default(usd)
  amountCents  Int
  title        String
  description  String?
  attachmentUrl String?
  attachmentName String?
  attachmentContentType String?
  submittedAt  DateTime               @default(now())
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  request MaintenanceRequest @relation(fields: [requestId], references: [id])
  vendor  Vendor             @relation(fields: [vendorId], references: [id])

  @@index([requestId, submittedAt])
  @@index([vendorId, submittedAt])
  @@index([orgId, submittedAt])
}

model VendorDispatchEvent {
  id             String         @id @default(cuid())
  requestId      String
  vendorId       String?
  actorUserId    String?
  status         DispatchStatus
  note           String?
  scheduledStart DateTime?
  scheduledEnd   DateTime?
  createdAt      DateTime       @default(now())

  request   MaintenanceRequest @relation(fields: [requestId], references: [id])
  vendor    Vendor?            @relation(fields: [vendorId], references: [id])
  actorUser User?              @relation(fields: [actorUserId], references: [id])
  photos    MaintenancePhoto[]

  @@index([requestId, createdAt])
}

model VendorDispatchLink {
  id             String    @id @default(cuid())
  requestId      String
  vendorId       String
  tenderInviteId String?
  tokenHash      String    @unique
  expiresAt      DateTime
  revokedAt      DateTime?
  lastUsedAt     DateTime?
  createdAt      DateTime  @default(now())

  request      MaintenanceRequest @relation(fields: [requestId], references: [id])
  vendor       Vendor             @relation(fields: [vendorId], references: [id])
  tenderInvite TenderInvite?      @relation(fields: [tenderInviteId], references: [id])

  @@index([requestId, vendorId])
}

model MaintenancePhoto {
  id              String      @id @default(cuid())
  requestId       String
  dispatchEventId String?
  imageUrl        String
  source          PhotoSource @default(tenant)
  sourceLabel     String?
  createdAt       DateTime    @default(now())

  request       MaintenanceRequest   @relation(fields: [requestId], references: [id])
  dispatchEvent VendorDispatchEvent? @relation(fields: [dispatchEventId], references: [id])
}

model RequestComment {
  id           String   @id @default(cuid())
  requestId    String
  authorUserId String?
  body         String
  visibility   String   @default("external")
  createdAt    DateTime @default(now())

  request MaintenanceRequest @relation(fields: [requestId], references: [id])
  author  User?              @relation(fields: [authorUserId], references: [id])
  inboundEmail InboundEmail?
}

model MailboxConnection {
  id                  String                  @id @default(cuid())
  userId              String
  provider            MailboxProvider
  status              MailboxConnectionStatus @default(connected)
  email               String
  displayName         String?
  providerAccountId   String?
  accessTokenCipher   String?
  refreshTokenCipher  String
  tokenExpiresAt      DateTime?
  scopesCsv           String?                 @default("")
  syncCursor          String?
  lastSyncedAt        DateTime?
  syncError           String?
  connectedAt         DateTime                @default(now())
  disconnectedAt      DateTime?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  user           User            @relation(fields: [userId], references: [id])
  outboundEmails OutboundEmail[]
  inboundEmails  InboundEmail[]

  @@unique([userId, provider])
  @@index([userId, status])
}

model OutboundEmail {
  id                    String              @id @default(cuid())
  userId                String?
  requestId             String?
  mailboxConnectionId   String?
  provider              MailboxProvider?
  transport             String
  status                EmailDeliveryStatus @default(pending)
  to                    String
  from                  String?
  subject               String
  messageIdHeader       String?
  providerMessageId     String?
  providerThreadId      String?
  error                 String?
  createdAt             DateTime            @default(now())
  sentAt                DateTime?

  user              User?              @relation(fields: [userId], references: [id])
  request           MaintenanceRequest? @relation(fields: [requestId], references: [id])
  mailboxConnection MailboxConnection?  @relation(fields: [mailboxConnectionId], references: [id])

  @@index([userId, createdAt])
  @@index([requestId, createdAt])
  @@index([providerMessageId])
  @@index([messageIdHeader])
}

model InboundEmail {
  id                   String              @id @default(cuid())
  userId               String
  requestId            String?
  mailboxConnectionId  String
  provider             MailboxProvider
  status               EmailDeliveryStatus @default(received)
  from                 String
  to                   String?
  subject              String
  textBody             String?
  htmlBody             String?
  providerMessageId    String
  providerThreadId     String?
  messageIdHeader      String?
  inReplyToHeader      String?
  receivedAt           DateTime?
  commentId            String?             @unique
  createdAt            DateTime            @default(now())

  user              User               @relation(fields: [userId], references: [id])
  request           MaintenanceRequest? @relation(fields: [requestId], references: [id])
  mailboxConnection MailboxConnection   @relation(fields: [mailboxConnectionId], references: [id])
  comment           RequestComment?     @relation(fields: [commentId], references: [id])

  @@unique([provider, providerMessageId])
  @@index([userId, createdAt])
  @@index([requestId, createdAt])
  @@index([providerThreadId])
}

model StatusEvent {
  id          String                @id @default(cuid())
  requestId   String
  fromStatus  RequestStatus?
  toStatus    RequestStatus
  actorUserId String?
  visibility  TenantEventVisibility @default(tenant_visible)
  createdAt   DateTime              @default(now())

  request   MaintenanceRequest @relation(fields: [requestId], references: [id])
  actorUser User?              @relation("StatusActor", fields: [actorUserId], references: [id])
}

model TenantIdentity {
  id          String               @id @default(cuid())
  orgId       String
  propertyId  String
  unitId      String
  tenantName  String
  phoneE164   String
  email       String?
  leaseStartDate DateTime?
  leaseEndDate   DateTime?
  status      TenantIdentityStatus @default(pending_invite)
  verifiedAt  DateTime?
  lastLoginAt DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  property      Property             @relation(fields: [propertyId], references: [id])
  unit          Unit                 @relation(fields: [unitId], references: [id])
  requests      MaintenanceRequest[]
  invites       TenantInvite[]
  otpChallenges TenantOtpChallenge[]
  sessions      TenantSession[]

  @@unique([orgId, phoneE164, unitId])
  @@index([orgId])
  @@index([propertyId])
  @@index([unitId])
}

model TenantInvite {
  id               String             @id @default(cuid())
  tenantIdentityId String
  orgId            String
  propertyId       String
  unitId           String
  tokenHash        String             @unique
  status           TenantInviteStatus @default(pending)
  expiresAt        DateTime
  sentVia          TenantOtpChannel
  sentTo           String
  createdAt        DateTime           @default(now())
  acceptedAt       DateTime?
  revokedAt        DateTime?

  tenantIdentity TenantIdentity @relation(fields: [tenantIdentityId], references: [id])

  @@index([tenantIdentityId, status])
  @@index([orgId, status])
}

model TenantOtpChallenge {
  id                String           @id @default(cuid())
  tenantIdentityId  String
  orgId             String
  purpose           TenantOtpPurpose
  channel           TenantOtpChannel
  destinationMasked String
  codeHash          String
  codeSalt          String
  expiresAt         DateTime
  attemptCount      Int              @default(0)
  maxAttempts       Int              @default(5)
  lockedUntil       DateTime?
  verifiedAt        DateTime?
  createdAt         DateTime         @default(now())

  tenantIdentity TenantIdentity @relation(fields: [tenantIdentityId], references: [id])

  @@index([tenantIdentityId, purpose, createdAt])
  @@index([orgId, purpose])
}

model TenantSession {
  id                String    @id @default(cuid())
  tenantIdentityId  String
  orgId             String
  propertyId        String
  unitId            String
  sessionSecretHash String    @unique
  issuedAt          DateTime  @default(now())
  expiresAt         DateTime
  revokedAt         DateTime?
  lastSeenAt        DateTime?
  userAgent         String?

  tenantIdentity TenantIdentity @relation(fields: [tenantIdentityId], references: [id])

  @@index([tenantIdentityId, revokedAt])
  @@index([orgId])
}

model VendorSession {
  id                String    @id @default(cuid())
  vendorId          String
  orgId             String?
  requestId         String?
  sessionSecretHash String    @unique
  issuedAt          DateTime  @default(now())
  expiresAt         DateTime
  revokedAt         DateTime?
  lastSeenAt        DateTime?
  userAgent         String?

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@index([vendorId, revokedAt])
  @@index([orgId])
  @@index([requestId])
}

model VendorOtpChallenge {
  id                String           @id @default(cuid())
  vendorId          String
  orgId             String?
  purpose           VendorOtpPurpose
  channel           VendorOtpChannel
  destinationMasked String
  codeHash          String
  codeSalt          String
  expiresAt         DateTime
  attemptCount      Int              @default(0)
  maxAttempts       Int              @default(5)
  lockedUntil       DateTime?
  verifiedAt        DateTime?
  createdAt         DateTime         @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@index([vendorId, purpose, createdAt])
  @@index([orgId, purpose])
}

model ManagerAccessCode {
  id               String                @id @default(cuid())
  orgId            String
  createdByUserId  String
  role             ManagerAccessCodeRole
  tenantIdentityId String?
  vendorId         String?
  propertyId       String?
  unitId           String?
  requestId        String?
  codeLookup       String
  codeHash         String
  codeSalt         String
  validFrom        DateTime              @default(now())
  expiresAt        DateTime
  attemptCount     Int                   @default(0)
  maxAttempts      Int                   @default(5)
  lockedUntil      DateTime?
  redeemedAt       DateTime?
  revokedAt        DateTime?
  createdAt        DateTime              @default(now())

  @@index([role, codeLookup])
  @@index([orgId, role, createdAt])
  @@index([tenantIdentityId, revokedAt])
  @@index([vendorId, revokedAt])
  @@index([requestId, revokedAt])
}

model BillingDocument {
  id              String                @id @default(cuid())
  requestId       String
  recipientType   BillingRecipientType
  documentType    BillingDocumentType
  status          BillingDocumentStatus @default(draft)
  currency        CurrencyOption        @default(usd)
  totalCents      Int
  paidCents       Int                   @default(0)
  title           String
  description     String?
  pdfUrl          String?
  sentTo          String?
  sentAt          DateTime?
  createdByUserId String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  request       MaintenanceRequest @relation(fields: [requestId], references: [id])
  createdByUser User?              @relation(fields: [createdByUserId], references: [id])
  events        BillingEvent[]

  @@index([requestId])
  @@index([status])
}

model BillingEvent {
  id                String   @id @default(cuid())
  billingDocumentId String
  actorUserId       String?
  eventType         String
  note              String?
  createdAt         DateTime @default(now())

  billingDocument BillingDocument @relation(fields: [billingDocumentId], references: [id])
  actorUser       User?           @relation(fields: [actorUserId], references: [id])

  @@index([billingDocumentId, createdAt])
}

model PushSubscription {
  id            String   @id @default(cuid())
  principalType String
  principalId   String
  endpoint      String   @unique
  p256dh        String
  auth          String
  userAgent     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([principalType, principalId])
}

model NativePushToken {
  id            String   @id @default(cuid())
  principalType String
  principalId   String
  token         String   @unique
  platform      String
  userAgent     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([principalType, principalId])
}

model AccountDeletionRequest {
  id          String   @id @default(cuid())
  userId      String?
  email       String
  reason      String?
  status      String   @default("pending")
  requestedAt DateTime @default(now())
  completedAt DateTime?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([status, requestedAt])
}

model AuditLog {
  id           String   @id @default(cuid())
  orgId        String?
  actorUserId  String?
  entityType   String
  entityId     String
  action       String
  summary      String
  metadataJson String?
  createdAt    DateTime @default(now())

  actorUser User? @relation(fields: [actorUserId], references: [id])

  @@index([orgId, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
}

model AutomationRule {
  id             String   @id @default(cuid())
  orgId          String
  name           String
  enabled        Boolean  @default(true)
  conditionField String
  conditionValue String
  actionType     String
  actionValue    String
  runCount       Int      @default(0)
  lastRunAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([orgId, enabled])
}

model ProductEvent {
  id           String   @id @default(cuid())
  orgId        String?
  eventName    String
  metadataJson String?
  createdAt    DateTime @default(now())

  @@index([orgId, eventName, createdAt])
}
